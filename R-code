# Scatterplot showing the relationship between social media hours and productivity score


ggplot(df, aes(
  x = social_media_hours, 
  y = productivity_score,
  color = cut(
    social_media_hours,
    breaks= c(0,2,4,6,8,10),
    labels= c("0-2","2-4","4-6","6-8","8-10")
    )
  ))+
  geom_point(size= 3) +
  geom_smooth(method = "lm", se = FALSE,color = "purple") +
  theme_minimal() +
  labs(
    title = "Relationship between social media hours and productivity score",
    x = "Social Media Hours",
    y = "Productivity score",
    color = "Hours Bucket"
  )




             #####                      #####
                 ##Data Visualization 2
            #####                      #####

library(scales)


# Prepare map data
map_data_final <- df |>
  rename(country = country) |>
  mutate(country = case_when(
    country == "United States of America" ~ "USA",
    country == "United Kingdom of Great Britain and Northern Ireland" ~ "UK",
    country == "United Arab Emirates" ~ "UAE",
    TRUE ~ country
  ))

# Grouping and averaging social 
map_data_final <- map_data_final %>%
  group_by(country) %>%
  summarise(
    social_media_hours = mean(social_media_hours, na.rm = TRUE)
  )

world_map <- map_data("world")

# Creating a map
socialmedia_usage_map <- ggplot() +
  
  geom_map(
    data = map_data_final,
    map = world_map,
    aes(map_id = country),
    color = "blue",
    fill = "grey",
    linewidth = 0.1
  ) +
  
  geom_map(
    data = map_data_final,
    map = world_map,
    aes(fill = social_media_hours,
        map_id = country)
  ) +
  
  expand_limits(
    x = world_map$long,
    y = world_map$lat
  ) +
  
  scale_fill_viridis_c(
    option = "plasma",
    trans = "log10",
    name = "Social Media Hours",
    na.value = "lightgray",
    labels = label_comma(),
    limits = c(1, NA)
  ) +
  
  theme_minimal() +
  
  labs(
    title = "Global Social Media Consumption",
    x = "",
    y = ""
  ) +
  
  theme(
    axis.text = element_blank(),
    axis.ticks = element_blank()
  )

# Display map
socialmedia_usage_map



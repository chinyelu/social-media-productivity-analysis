         #####Summmary Table#######
##################  ##################
summary_table <- df %>%
  
  group_by(education_level) %>% 
  summarise(
    productivity_score_mean = mean(productivity_score, na.rm = TRUE),
    social_media_hours_mean = mean(social_media_hours, na.rm = TRUE),
    wellbeing_index_mean = mean(wellbeing_index, na.rm = TRUE),
    attention_span_mean = mean(attention_span_minutes, na.rm = TRUE),

    productivity_score_median = median(productivity_score, na.rm = TRUE),
    social_media_hours_median = median(social_media_hours, na.rm = TRUE),
    wellbeing_index_median = median(wellbeing_index, na.rm = TRUE),
    attention_span_median = median(attention_span_minutes, na.rm = TRUE),
    
    productivity_score_sd = sd(productivity_score, na.rm = TRUE),
    social_media_hours_sd = sd(social_media_hours, na.rm = TRUE),
    wellbeing_index_sd = sd(wellbeing_index, na.rm = TRUE),
    attention_span_sd = median(attention_span_minutes, na.rm = TRUE),

  )

write.csv(summary_table, "summary_table1.csv", row.names = FALSE)

